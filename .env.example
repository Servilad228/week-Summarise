# --- TELEGRAM CONFIGURATION ---
# Get API_ID and API_HASH from https://my.telegram.org/
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# The Telegram chat/group/channel to fetch message history from.
# Can be a username (e.g. @group_username) or integer ID (e.g. -100123456789)
TELEGRAM_CHAT_ID=-100123456789

# Where to send the summary. Comma-separated list of usernames or IDs.
# Use 'me' (without quotes) to send to your own Saved Messages.
TELEGRAM_TARGET_CHATS=me

# Path where Telethon session file will be stored.
SESSION_NAME=data/session

# --- OPENROUTER CONFIGURATION ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Suggested default: google/gemini-2.5-flash for speed, cost, and huge context window.
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- SCHEDULING CONFIGURATION ---
# Choose run mode: 'interval' or 'scheduled'
RUN_MODE=interval

# 1. Interval mode settings (runs every X days from the last execution)
INTERVAL_DAYS=7

# 2. Scheduled mode settings (runs on a specific day and time)
# Weekday can be: monday, tuesday, wednesday, thursday, friday, saturday, sunday
SCHEDULE_WEEKDAY=sunday
# Time in HH:MM format (24-hour clock)
SCHEDULE_TIME=20:00
# Timezone list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones (e.g. Europe/Moscow)
TIMEZONE=Europe/Moscow

# --- PERFORMANCE & STORAGE ---
# Maximum number of messages to fetch per summary run to prevent token overflow.
MAX_MESSAGES_LIMIT=5000

# Path to persistent state file
STATE_FILE_PATH=data/state.json
